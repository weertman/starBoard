[Unit]
Description=starBoard MegaStar Worker (localhost only)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=weertman
Group=weertman
WorkingDirectory=/home/weertman/Documents/starBoard
Environment=STARBOARD_ARCHIVE_DIR=/home/weertman/Documents/starBoard/archive
Environment=STARBOARD_MEGASTAR_WORKER_ENABLED=1
Environment=STARBOARD_MEGASTAR_MODEL_KEY=default_megastarid_v1
Environment=STARBOARD_MEGASTAR_REQUIRE_FRESH_ASSETS=1
Environment=STARBOARD_MEGASTAR_WORKER_HOST=127.0.0.1
Environment=STARBOARD_MEGASTAR_WORKER_PORT=8093
ExecStart=/bin/bash /home/weertman/Documents/starBoard/scripts/python -m uvicorn mobile_portal.megastar_worker.main:app --host 127.0.0.1 --port 8093
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
